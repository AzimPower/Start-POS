# Configuration de l'API Backend
VITE_API_URL=https://start-pos.com//api

# Configuration backend PHP/MySQL
DB_HOST=127.0.0.1
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4
APP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.com
APP_AUTH_SECRET=change-this-long-random-secret
APP_DEFAULT_ADMIN_EMAIL=admin@example.com
VITE_DEFAULT_ADMIN_EMAIL=admin@example.com

# Configuration SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=START POS - Notification

# Configuration PWA
VITE_APP_NAME=OneClick POS
VITE_APP_SHORT_NAME=OneClick

# Configuration de synchronisation
VITE_SYNC_INTERVAL=30000
VITE_AUTO_SYNC=true

# Configuration de développement
VITE_DEV_MODE=true
